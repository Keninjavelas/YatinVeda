# =============================================================================
# YatinVeda — Root Environment Configuration
# =============================================================================
# Copy this file to .env in the project root and update values.
# Docker Compose reads this file automatically.
# For Kubernetes, set variables via Secrets / ConfigMaps.
# =============================================================================

# ── Environment ──────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@postgres:5432/yatinveda
DB_POOL_SIZE=5                   # Connection pool size (increase for prod)
DB_MAX_OVERFLOW=10               # Extra connections allowed beyond pool size
DB_POOL_TIMEOUT=30               # Seconds to wait for a pool connection
DB_POOL_RECYCLE=3600             # Recycle connections after N seconds
# DB_ECHO=false                  # Log all SQL statements (debug only)

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0   # Set to "memory://" to disable Redis

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
CSRF_PROTECTION_ENABLED=true     # Should be true in production
# CSRF_SECRET_KEY=               # Defaults to SECRET_KEY if not set
# CSRF_TOKEN_LIFETIME=3600
# CSRF_DOUBLE_SUBMIT=true

# ── CORS ─────────────────────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost

# ── HTTPS / Cookies ──────────────────────────────────────────────────────────
# COOKIE_SECURE=true             # Set true in production (requires HTTPS)
# ENABLE_HTTPS=true              # Set true in production

# ── Email ────────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=mock              # mock | smtp | sendgrid
EMAIL_FROM=noreply@yatinveda.com
# SENDGRID_API_KEY=
SMTP_SERVER=localhost
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# ── Payments (Razorpay) ─────────────────────────────────────────────────────
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# ── LLM / AI ────────────────────────────────────────────────────────────────
LLM_PROVIDER=local               # local | openai | anthropic
# OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
# ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-sonnet-20240229
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3.1:8b-instruct-q4_K_M

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ── Observability / Tracing ──────────────────────────────────────────────────
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR | CRITICAL
# SERVICE_NAME=yatinveda-backend
# OTLP_ENDPOINT=http://localhost:4317
# JAEGER_ENDPOINT=localhost:6831
# TRACE_CONSOLE_EXPORT=false

# ── Security Monitoring ──────────────────────────────────────────────────────
# SECURITY_ALERT_WEBHOOK=        # Slack / Teams webhook URL for security alerts
# SECURITY_LOG_LEVEL=INFO

# ── Cleanup Scheduler ───────────────────────────────────────────────────────
# CLEANUP_INTERVAL_HOURS=1
# CLEANUP_INTERVAL_MINUTES=0
# CLEANUP_INTERVAL_SECONDS=3600

# ── Rate Limiting ────────────────────────────────────────────────────────────
DISABLE_RATELIMIT=0              # Set to 1 to disable (dev/test only)

# ── Development ──────────────────────────────────────────────────────────────
RELOAD=true                      # Hot-reload (dev only, set false in prod)
