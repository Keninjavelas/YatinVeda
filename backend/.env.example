# Environment Configuration for YatinVeda Backend

# Copy this file to .env and update values for your environment

# ============================================================================
# Core Application Settings
# ============================================================================
PROJECT_NAME=YatinVeda API
VERSION=1.0.0
ENVIRONMENT=development  # development, staging, production

# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/yatinveda

# ============================================================================
# Security Settings
# ============================================================================
SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ============================================================================
# CORS Settings
# ============================================================================
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================================================
# Redis Cache (Optional - for production)
# ============================================================================
# Uncomment and configure to enable Redis caching
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=  # Leave empty if no password

# ============================================================================
# OpenTelemetry Tracing (Optional - for observability)
# ============================================================================
# Uncomment and configure to enable distributed tracing

# Service identification
# SERVICE_NAME=yatinveda-backend

# OTLP Exporter (recommended for production)
# OTLP_ENDPOINT=http://localhost:4317  # OpenTelemetry Collector

# Jaeger Exporter (alternative)
# JAEGER_ENDPOINT=localhost:6831

# Console export (for debugging)
# TRACE_CONSOLE_EXPORT=false

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# ============================================================================
# Performance Settings
# ============================================================================
# Enable/disable features
RELOAD=true  # Auto-reload on code changes (development only)
DISABLE_RATELIMIT=0  # Set to 1 to disable rate limiting

# ============================================================================
# External Services
# ============================================================================
# Email service (if configured)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAIL_FROM=noreply@yatinveda.com

# Payment gateway (Razorpay)
# RAZORPAY_KEY_ID=your-key-id
# RAZORPAY_KEY_SECRET=your-key-secret
# RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ============================================================================
# LLM Configuration (AI Assistant)
# ============================================================================
# Provider options: "openai", "anthropic", "local"
LLM_PROVIDER=openai

# OpenAI Configuration (for GPT-4, GPT-3.5)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4

# Anthropic Configuration (for Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Local LLM Configuration (for Ollama)
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama2

# MFA Encryption Key
MFA_ENCRYPTION_KEY=your-encryption-key-for-totp-secrets

# ============================================================================
# Internationalization & Currency
# ============================================================================
# Default currency for the platform
DEFAULT_CURRENCY=USD

# Currency API for exchange rates
CURRENCY_PROVIDER=manual  # options: openexchangerates, currencyapi, manual
CURRENCY_API_KEY=your-currency-api-key-here  # Required for openexchangerates or currencyapi

# Supported currencies (comma-separated ISO 4217 codes)
SUPPORTED_CURRENCIES=USD,EUR,GBP,INR,AUD,CAD,SGD,AED,JPY,CNY

# Default timezone
DEFAULT_TIMEZONE=UTC

# Supported languages (comma-separated)
SUPPORTED_LANGUAGES=en,es,fr,de,hi,zh,ja,pt,ar

# ============================================================================
# CDN Configuration
# ============================================================================
# CDN domains for Content Security Policy (comma-separated)
CDN_DOMAINS=cdn.yatinveda.com,assets.yatinveda.com

# CDN base URL for static assets
CDN_BASE_URL=https://cdn.yatinveda.com

# ============================================================================
# Legal & Compliance
# ============================================================================
# GDPR data export/deletion settings
DATA_EXPORT_RETENTION_DAYS=30  # How long export files are available
ANONYMIZE_ON_DELETION=true  # Anonymize instead of hard delete for compliance

# ============================================================================
# Monitoring & Observability
# ============================================================================
# Health check configuration
HEALTH_CHECK_TIMEOUT=5  # seconds

# ============================================================================
# Notes
# ============================================================================
# - Never commit .env file to version control
# - Use different values for development, staging, and production
# - Store production secrets in secure vault (AWS Secrets Manager, Azure Key Vault, etc.)
# - Redis and OpenTelemetry are optional - app works without them
