# ============================================================
# YatinVeda – Local Development Environment
# ============================================================
# Safe to use for testing without any paid API keys.
# Payments run in MOCK MODE (fake responses, no real charges).
# AI assistant falls back to local LLM (Ollama) or no-op.
# Email is logged to console (mock mode).
# ============================================================

# ── Application ─────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=dev-secret-key-not-for-production-use
RELOAD=true

# ── Database – SQLite for dev (no setup needed) ───────────────
DATABASE_URL=sqlite:///./yatinveda.db

# ── Auth cookies (relaxed for HTTP localhost) ────────────────
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
REFRESH_TOKEN_BINDING=false

# ── CORS – allow local frontend ──────────────────────────────
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NODE_ENV=development

# ── Payments – MOCK MODE (no real Razorpay keys needed) ──────
# Leave these blank → automatically activates mock payment mode.
# Mock mode: create-order, verify-payment, refunds all return
# realistic fake responses. No money moves.
PAYMENT_MOCK_MODE=true
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── AI Assistant – uses local Ollama if running, else no-op ──
# If you have Ollama installed: `ollama run llama3.1` then set:
LLM_PROVIDER=local
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Email – logged to console, no real emails sent ───────────
EMAIL_PROVIDER=mock
EMAIL_FROM=dev@localhost

# ── MFA encryption (dev key – not for production) ────────────
MFA_ENCRYPTION_KEY=T3QkXHBUO6eIfFqaJwXRXJQk7oivdpCv2OBbHw1Ot3M=

# ── Rate limiting – disabled so dev isn't throttled ──────────
DISABLE_RATELIMIT=1

# ── CSRF – disabled for easier local API testing ─────────────
CSRF_PROTECTION_ENABLED=false
